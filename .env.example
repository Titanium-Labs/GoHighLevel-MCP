GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_LOCATION_ID=your-location-id
MCP_SERVER_PORT=8003
NODE_ENV=development

# OAuth via MongoDB (preferred)
MONGO_URI=mongodb://user:pass@host:27017/dbname?authSource=admin
GHL_COMPANY_ID=your-company-id
GHL_APP_CLIENT_ID=your-app-client-id
GHL_APP_CLIENT_SECRET=your-app-client-secret

# Fallback static token (optional, used if MONGO_URI not set)
# GHL_API_KEY=pit-xxx
